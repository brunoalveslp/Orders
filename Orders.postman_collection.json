{
  "info": {
    "name": "Orders API",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Coleção de testes para a Orders API. Importe este arquivo no Postman para testar todos os endpoints.\n\n**Base URL:** `http://localhost:8080` (HTTP) ou `https://localhost:8081` (HTTPS)\n\n**Como usar:**\n1. Execute `docker compose up --build` na pasta raiz do projeto\n2. Importe este arquivo no Postman (File → Import)\n3. Selecione o environment `Orders API - Local`\n4. Execute `POST /order` primeiro — o `orderId` será salvo automaticamente como variável de coleção\n5. Use `GET /order/{id}` para consultar o pedido criado",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "URL base da API. Substitua por https://localhost:8081 para HTTPS."
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string",
      "description": "ID do último pedido criado. Preenchido automaticamente pelo script do POST /order."
    }
  ],
