        {
          "name": "Criar pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    if (json && json.id) {",
                  "        pm.collectionVariables.set('orderId', json.id);",
                  "        console.log('orderId salvo:', json.id);",
                  "    }",
                  "}",
                  "",
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Resposta contém id', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('id');",
                  "    pm.expect(json.id).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('Status do pedido é Pendente', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.eql('Pendente');",
                  "});",
                  "",
                  "pm.test('Valor retornado corresponde ao enviado', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.valor).to.eql(4500.00);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nomeCliente\": \"João Silva\",\n  \"descricao\": \"Pedido de notebook\",\n  \"valor\": 4500.00\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/order",
              "host": ["{{baseUrl}}"],
              "path": ["order"]
            },
            "description": "Cria um novo pedido. O `id` retornado é salvo automaticamente na variável de coleção `{{orderId}}` para uso nas demais requisições.\n\nApós a criação, o evento `OrderCreatedEvent` é publicado na fila `orders` do RabbitMQ e o Worker processa o pedido de forma assíncrona, alterando o status de `Pendente` para `Processado`.\n\n**Body:**\n```json\n{\n  \"nomeCliente\": \"string (obrigatório)\",\n  \"descricao\": \"string (obrigatório)\",\n  \"valor\": 0.00\n}\n```\n\n**Resposta 201 Created:**\n```json\n{\n  \"id\": \"3fa85f64-5717-4562-b3fc-2c963f66afa6\",\n  \"nomeCliente\": \"João Silva\",\n  \"descricao\": \"Pedido de notebook\",\n  \"valor\": 4500.00,\n  \"status\": \"Pendente\"\n}\n```"
          },
